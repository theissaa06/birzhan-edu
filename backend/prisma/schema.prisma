generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum SystemRole {
  ADMIN
  DEVELOPER
  OWNER
}

enum AccountStatus {
  ACTIVE
  DEACTIVATED
}

enum BanStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum PremiumOverrideMode {
  FORCE_ENABLED
  FORCE_DISABLED
}

enum SubscriptionStatus {
  ACTIVE
  GRACE
  CANCELED
  EXPIRED
  PENDING
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

enum OAuthProvider {
  GOOGLE
  APPLE
  TELEGRAM
  VK
}

enum CertificateStatus {
  ACTIVE
  REVOKED
}

enum AnnouncementAudience {
  ALL
  USERS
  PREMIUM
  STAFF
}

enum LessonType {
  VIDEO
  TEXT
  PRACTICE
}

enum VideoReviewStatus {
  MANUAL_REQUIRED
  QUEUED
  PROCESSING
  APPROVED
  NEEDS_CHANGES
  FAILED
  APPEALED
  MANUAL_APPROVED
  MANUAL_NEEDS_CHANGES
}

enum SubmissionAppealStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               Int           @id @default(autoincrement())
  username         String
  email            String        @unique
  password         String?
  phone            String?
  role             Role          @default(USER)
  badges           String[]      @default([])
  accountStatus    AccountStatus @default(ACTIVE)
  deactivatedAt    DateTime?
  blockedAt        DateTime?
  blockedUntil     DateTime?
  blockedReason    String?
  blockedById      Int?
  isPhoneVerified  Boolean       @default(false)
  sessionVersion   Int           @default(0)
  isPremium        Boolean       @default(false)
  premiumPlan      String?
  premiumStarted   DateTime?
  premiumUntil     DateTime?
  lastSeenAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  lessonProgress        LessonProgress[]
  userBonuses           UserBonus[]
  supportMessages       SupportMessage[]
  paymentTransactions   PaymentTransaction[]
  passwordResetTokens   PasswordResetToken[]
  assignmentSubmissions AssignmentSubmission[]
  reviews               Review[]
  subscriptions         Subscription[]
  payments              Payment[]
  roles                 UserRole[]             @relation("UserRoles")
  rolesGranted          UserRole[]             @relation("UserRoleGrantor")
  bansReceived          UserBan[]              @relation("BanTarget")
  bansIssued            UserBan[]              @relation("BanActor")
  bansRevoked           UserBan[]              @relation("BanRevoker")
  auditEntries          AuditLog[]             @relation("AuditActor")
  auditTargets          AuditLog[]             @relation("AuditTarget")
  notifications         Notification[]
  announcementsCreated  Announcement[]         @relation("AnnouncementCreator")
  announcementReads     AnnouncementRead[]
  premiumOverride       PremiumOverride?
  premiumActions        PremiumOverride[]      @relation("PremiumOverrideActor")
  subscriptionEvents    SubscriptionEvent[]    @relation("SubscriptionEventUser")
  subscriptionActions   SubscriptionEvent[]    @relation("SubscriptionEventActor")
  oauthIdentities       OAuthIdentity[]
  oauthAttempts         OAuthLoginAttempt[]
  avatar                UserAvatar?
  certificates          Certificate[]
  reviewComments        ReviewComment[]
  officialReplies       ReviewOfficialReply[]
  jobApplications       JobApplication[]
  submissionAppeals     SubmissionAppeal[]    @relation("SubmissionAppealUser")
  appealsReviewed       SubmissionAppeal[]    @relation("SubmissionAppealReviewer")

  @@index([accountStatus])
  @@index([blockedUntil])
}

model UserAvatar {
  userId    Int      @id
  kind      String
  presetId  String?
  imageData Bytes?
  mimeType  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([kind])
}

model UserRole {
  id          Int        @id @default(autoincrement())
  userId      Int
  role        SystemRole
  grantedById Int?
  grantedAt   DateTime   @default(now())
  user        User       @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User?      @relation("UserRoleGrantor", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, role])
  @@index([role])
}

model UserBan {
  id          Int       @id @default(autoincrement())
  userId      Int
  actorId     Int?
  revokedById Int?
  reason      String
  status      BanStatus @default(ACTIVE)
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation("BanTarget", fields: [userId], references: [id], onDelete: Cascade)
  actor       User?     @relation("BanActor", fields: [actorId], references: [id], onDelete: SetNull)
  revokedBy   User?     @relation("BanRevoker", fields: [revokedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status, endsAt])
}

model AuditLog {
  id           BigInt   @id @default(autoincrement())
  actorId      Int?
  targetUserId Int?
  action       String
  entityType   String
  entityId     String?
  before       Json?
  after        Json?
  metadata     Json?
  ip           String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetUser   User?    @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([targetUserId, createdAt])
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  message   String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Announcement {
  id        Int                  @id @default(autoincrement())
  title     String
  message   String
  audience  AnnouncementAudience @default(ALL)
  activeFrom DateTime             @default(now())
  activeUntil DateTime?
  createdById Int?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  createdBy User?                 @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: SetNull)
  reads     AnnouncementRead[]

  @@index([activeFrom, activeUntil])
}

model AnnouncementRead {
  id             Int          @id @default(autoincrement())
  announcementId Int
  userId         Int
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

model Subscription {
  id          Int                @id @default(autoincrement())
  userId      Int
  plan        String
  price       Int
  currency    String             @default("KZT")
  status      SubscriptionStatus @default(PENDING)
  startedAt   DateTime?
  expiresAt   DateTime?
  graceUntil  DateTime?
  canceledAt  DateTime?
  provider    String?
  providerId  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments    Payment[]
  events      SubscriptionEvent[]

  @@unique([provider, providerId])
  @@index([userId, status])
  @@index([expiresAt])
}

model Payment {
  id             Int           @id @default(autoincrement())
  userId         Int
  subscriptionId Int?
  amount         Int
  currency       String        @default("KZT")
  status         PaymentStatus @default(PENDING)
  provider       String?
  providerId     String?
  description    String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model PremiumOverride {
  id         Int                 @id @default(autoincrement())
  userId     Int                 @unique
  mode       PremiumOverrideMode
  validUntil DateTime?
  reason     String
  actorId    Int?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor      User?               @relation("PremiumOverrideActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([mode, validUntil])
}

model SubscriptionEvent {
  id             BigInt        @id @default(autoincrement())
  subscriptionId Int?
  userId         Int
  actorId        Int?
  type           String
  idempotencyKey String        @unique
  payload        Json?
  createdAt      DateTime      @default(now())
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user           User          @relation("SubscriptionEventUser", fields: [userId], references: [id], onDelete: Cascade)
  actor          User?         @relation("SubscriptionEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model OAuthIdentity {
  id             Int           @id @default(autoincrement())
  userId         Int
  provider       OAuthProvider
  providerUserId String
  emailSnapshot  String?
  displayName    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
}

model OAuthLoginAttempt {
  id               Int           @id @default(autoincrement())
  provider         OAuthProvider
  stateHash        String        @unique
  nonceHash        String?
  codeVerifier     String?
  exchangeCodeHash String?       @unique
  redirectPath     String?
  userId           Int?
  expiresAt        DateTime
  usedAt           DateTime?
  exchangedAt      DateTime?
  createdAt        DateTime      @default(now())
  user             User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([provider, expiresAt])
}

model Certificate {
  id             Int               @id @default(autoincrement())
  code           String            @unique
  userId         Int
  courseId       Int
  recipientName  String
  courseTitle    String
  status         CertificateStatus @default(ACTIVE)
  issuedAt       DateTime          @default(now())
  revokedAt      DateTime?
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course            @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@unique([userId, courseId])
  @@index([status, issuedAt])
}

model Course {
  id          Int       @id @default(autoincrement())
  title       String
  category    String
  level       String
  duration    String
  description String
  imageUrl    String?
  isPremium   Boolean   @default(false)
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lessons     Lesson[]
  certificates Certificate[]
}

model Lesson {
  id           Int              @id @default(autoincrement())
  title        String
  content      String?
  description  String?
  whatYouLearn String?
  steps        String?
  taskText     String?
  beginnerHelp String?
  hints        String?
  videoUrl     String?
  orderNumber  Int
  type         LessonType       @default(VIDEO)
  isPublished  Boolean          @default(true)
  autoReviewEnabled Boolean     @default(false)
  courseId     Int
  course       Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  progress     LessonProgress[]
  submissions  AssignmentSubmission[]
  reviewCriteria LessonReviewCriterion[]
}

model LessonReviewCriterion {
  id            Int      @id @default(autoincrement())
  lessonId      Int
  key           String
  title         String
  description   String
  kind          String
  required      Boolean  @default(true)
  minValue      Float?
  maxValue      Float?
  expectedValue String?
  weight        Int      @default(1)
  orderNumber   Int      @default(1)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, key])
  @@index([lessonId, active, orderNumber])
}

model LessonProgress {
  id          Int       @id @default(autoincrement())
  userId      Int
  lessonId    Int
  courseId    Int?
  started     Boolean   @default(false)
  completed   Boolean   @default(false)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Bonus {
  id          Int         @id @default(autoincrement())
  title       String
  description String
  status      String      @default("available")
  requirement String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userBonuses UserBonus[]
}

model UserBonus {
  id        Int      @id @default(autoincrement())
  userId    Int
  bonusId   Int
  claimed   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bonus     Bonus    @relation(fields: [bonusId], references: [id], onDelete: Cascade)

  @@unique([userId, bonusId])
}

model Review {
  id            Int                   @id @default(autoincrement())
  name          String
  text          String
  rating        Int
  direction     String?
  userId        Int?                  @unique
  isHidden      Boolean               @default(false)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  comments      ReviewComment[]
  officialReply ReviewOfficialReply?
}

model ReviewComment {
  id        Int      @id @default(autoincrement())
  reviewId  Int
  authorId  Int
  text      String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
}

model ReviewOfficialReply {
  id        Int      @id @default(autoincrement())
  reviewId  Int      @unique
  authorId  Int
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
}

model MediaArticle {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  category    String
  type        String
  imageUrl    String?
  content     String?
  createdAt   DateTime @default(now())
}

model Webinar {
  id              Int      @id @default(autoincrement())
  title           String
  description     String
  startsAt        DateTime
  durationMinutes Int      @default(60)
  registrationUrl String?
  imageUrl         String?
  isPublished      Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isPublished, startsAt])
}

model JobPosting {
  id             Int      @id @default(autoincrement())
  title          String
  company        String
  location       String
  employmentType String
  description    String
  salary         String?
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  applications   JobApplication[]

  @@index([isPublished, createdAt])
}

model JobApplication {
  id        Int        @id @default(autoincrement())
  jobId     Int
  userId    Int?
  name      String
  email     String
  phone     String?
  message   String?
  status    String     @default("new")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  job       JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([jobId, status])
  @@index([userId])
}

model SupportMessage {
  id              Int              @id @default(autoincrement())
  text            String
  from            String
  name            String?
  email           String?
  topic           String?
  status          String           @default("open")
  userId          Int?
  parentId        Int?
  clientRequestId String?          @unique
  createdAt       DateTime         @default(now())
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  parent          SupportMessage?  @relation("SupportThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies         SupportMessage[] @relation("SupportThread")

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([parentId, createdAt])
}

model Application {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  type      String
  message   String?
  createdAt DateTime @default(now())
}

model PaymentTransaction {
  id            Int      @id @default(autoincrement())
  userId        Int
  provider      String
  transactionId String
  plan          String?
  amount        Int
  currency      String   @default("KZT")
  status        String
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, transactionId])
  @@index([userId])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AssignmentSubmission {
  id        Int      @id @default(autoincrement())
  userId    Int
  lessonId  Int
  courseId  Int?
  type      String
  url       String?
  notes     String?
  status    String   @default("submitted")
  feedback  String?
  isPublic  Boolean  @default(false)
  attemptNumber Int   @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  autoReview SubmissionAutoReview?
  appeal     SubmissionAppeal?

  @@index([userId])
  @@index([lessonId])
  @@index([courseId])
  @@index([status])
}

model SubmissionAutoReview {
  id                Int               @id @default(autoincrement())
  submissionId      Int               @unique
  status            VideoReviewStatus @default(MANUAL_REQUIRED)
  criteriaSnapshot  Json
  technicalMetadata Json?
  result             Json?
  provider           String?
  model              String?
  errorCode          String?
  errorMessage       String?
  leaseExpiresAt     DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  submission         AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([leaseExpiresAt])
}

model SubmissionAppeal {
  id           Int                    @id @default(autoincrement())
  submissionId Int                    @unique
  userId       Int
  reviewerId   Int?
  reason       String
  status       SubmissionAppealStatus @default(PENDING)
  resolution   String?
  createdAt    DateTime               @default(now())
  resolvedAt   DateTime?
  submission   AssignmentSubmission   @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user         User                   @relation("SubmissionAppealUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer     User?                  @relation("SubmissionAppealReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}
