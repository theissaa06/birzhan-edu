PORT=3003
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/birzhan_edu
JWT_SECRET=change-me
OWNER_ID=
OWNER_EMAIL=
TRUST_PROXY=

# Exact public frontend origin for CORS, for example:
# FRONTEND_URL=https://your-frame-school.layero.app
FRONTEND_URL=http://localhost:5173
# Optional comma-separated extra origins:
# FRONTEND_URLS=http://127.0.0.1:5173,http://192.168.x.x:5173,https://preview.example.com

# Optional production uptime/monitoring helpers:
# PUBLIC_BACKEND_URL=https://your-backend.layero.app
# KEEP_ALIVE_URLS=https://your-backend.layero.app/health
# KEEP_ALIVE_INTERVAL_MS=300000

TURNSTILE_SECRET_KEY=
# When true, a missing secret is a configuration error and auth fails closed.
TURNSTILE_REQUIRED=false
TURNSTILE_TIMEOUT_MS=5000
ALLOW_TURNSTILE_BYPASS=false

# Password reset email provider
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Frame School <no-reply@example.com>"
# Never enable in production. Allows the reset code to be returned in the API response for local development only.
AUTH_ALLOW_DEV_RESET_CODE=false
APP_TIMEZONE=Asia/Almaty

# Gemini AI. Leave GEMINI_API_KEY empty only for explicit degraded demo mode.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Demo answers are disabled in production unless explicitly enabled.
AI_ALLOW_DEMO_FALLBACK=false

# Cloudflare R2 uploads for practical assignments
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
MAX_VIDEO_UPLOAD_MB=300

# OAuth. Each button stays disabled until every required key for that provider is present.
OAUTH_REDIRECT_BASE_URL=http://localhost:3003
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
TELEGRAM_BOT_NAME=
TELEGRAM_BOT_TOKEN=
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Regional payments. Public IDs belong only in frontend variables.
TIPTOPPAY_API_SECRET=
CLOUDPAYMENTS_API_SECRET=
PREMIUM_AMOUNT_KZT=4990
PREMIUM_AMOUNT_RUB=990
ALLOW_PREMIUM_DEV_OVERRIDE=false
