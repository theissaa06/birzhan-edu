{
  "name": "frame-school-backend",
  "version": "1.0.0",
  "description": "Frame School Platform Backend",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "admin:grant": "node scripts/grant-privileged-user.js",
    "start": "node src/server.js",
    "start:prod": "npm run db:migrate && node src/server.js",
    "lint": "node scripts/check-syntax.js",
    "typecheck": "prisma validate",
    "test": "node --test test/*.test.js",
    "build": "npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@google/genai": "^1.52.0",
    "@marsidev/react-turnstile": "^1.5.2",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "nodemailer": "^9.0.3",
    "prisma": "^5.14.0"
    ,"qrcode": "^1.5.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
